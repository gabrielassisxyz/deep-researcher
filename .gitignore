
# Captured documentation corpora and local build artifacts.
.venv/
__pycache__/
*.egg-info/


# pi's MCP extension is per-user; the server config (.pi/mcp.json) IS committed.

# Your machine, not this project.
.deep-research.conf

# Generated by scripts/deep-research-pi from .deep-research.conf
.pi/mcp.json

# Generated by scripts/install-firecrawl — carries the generated passwords.
infra/firecrawl/.env

# stderr captured from reviewers is a debugging aid, not an artifact.
*.stderr

# >>> repo-harness:gitignore-private-boundary >>>
# Maintainer notes — not part of the project; they live in the private notes repo,
# reachable through the `local` symlink. NO trailing slash on any path in this block:
# a worktree materializes these paths as SYMLINKS, and a `foo/` pattern matches a real
# directory only — the ignore then keeps working in the main tree and silently fails
# in every worktree.
/local

# Environment secrets and the per-machine agent sandbox config.
.env
.ai-jail
# <<< repo-harness:gitignore-private-boundary <<<
