#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [ "$#" -eq 0 ]; then
  echo "Usage: scripts/deep-research-codex '<research request>'" >&2
  echo "Example: scripts/deep-research-codex \"$(tr '\n' ' ' < "$ROOT/prompts/examples/llm-models-golden.md" | sed 's/"/\\"/g')\"" >&2
  exit 2
fi

cd "$ROOT"
codex exec \
  --cd "$ROOT" \
  --sandbox danger-full-access \
  "$(printf 'Read and follow codex/prompts/deep-research.md. User research request:\n\n%s\n' "$*")"

