#!/usr/bin/env bash
# Run the deep-research workflow through pi, against a model served by the local LiteLLM.
#
# WHY pi is worth a script of its own: it is the cheap harness. The whole point of routing
# research to GLM-5.2 (or another LiteLLM-served model) is that a deep run makes dozens of
# tool calls, and doing that on a frontier model costs real money for work that is mostly
# fetching and summarising. Use the expensive harnesses when the *reasoning* is the hard
# part; use this one for the legwork.
#
# pi reaches Firecrawl and academic-paper MCPs through the pi-mcp-extension
# (`pi install npm:pi-mcp-extension`), configured by `.pi/mcp.json` in this repo. Without
# that extension pi has no source access at all -- read, bash, edit, write and nothing else
# -- and the research prompt will (correctly) refuse to proceed rather than write a dossier
# from the model's memory.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CONF="$ROOT/.deep-research.conf"

if [ ! -f "$CONF" ]; then
    echo "No setup found. Run scripts/setup first — it detects what this machine has and asks" >&2
    echo "what you want to use (researching model, second opinion, review panel, depth budget)." >&2
    exit 2
fi
# The environment wins over the config file. Sourcing the config *after* reading the
# environment would silently clobber an explicit `FIRECRAWL_API_URL=... ./deep-research-pi`
# — the override would appear to work, be ignored, and the run would quietly proceed against
# whatever the file said. That is how a dependency check ends up checking the wrong thing:
# pointing the URL at a dead port to test the guard would test the live one instead.
_env_url="${FIRECRAWL_API_URL:-}"
_env_key="${FIRECRAWL_API_KEY:-}"
_env_model="${DEEP_RESEARCH_MODEL:-}"

# shellcheck disable=SC1090
. "$CONF"

[ -n "$_env_url" ] && FIRECRAWL_API_URL="$_env_url"
[ -n "$_env_key" ] && FIRECRAWL_API_KEY="$_env_key"
[ -n "$_env_model" ] && RESEARCH_MODEL="$_env_model"

export FIRECRAWL_API_URL="${FIRECRAWL_API_URL:-http://localhost:3002}"
export FIRECRAWL_API_KEY="${FIRECRAWL_API_KEY:-}"

# pi-mcp-extension does NOT expand placeholders in .pi/mcp.json -- not `{env:VAR}`, not
# `${VAR}`. It passes the literal string through to firecrawl-mcp, which rejects it with a
# bare "Invalid URL" and no hint as to why. (opencode's config DOES expand `{env:VAR}`, which
# is exactly the sort of difference that makes a tool work on its author's machine and nowhere
# else.) So the file is generated from the config rather than templated: one source of truth,
# and the cloud path works without hand-editing JSON.
mkdir -p "$ROOT/.pi"
cat > "$ROOT/.pi/mcp.json" <<EOF
{
  "settings": { "toolPrefix": "mcp", "requestTimeoutMs": 60000, "maxRetries": 3 },
  "mcpServers": {
    "firecrawl": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_URL": "$FIRECRAWL_API_URL",
        "FIRECRAWL_API_KEY": "$FIRECRAWL_API_KEY"
      },
      "lifecycle": "eager"
    },
    "arxiv": {
      "transport": "stdio",
      "command": "bash",
      "args": ["-lc", "mkdir -p .ai-jail/arxiv-papers && exec uvx arxiv-mcp-server --storage-path .ai-jail/arxiv-papers"],
      "lifecycle": "eager"
    },
    "paper_search": {
      "transport": "stdio",
      "command": "bash",
      "args": ["-lc", "set -a; [ -f local/paper-search-mcp.env ] && . local/paper-search-mcp.env; set +a; mkdir -p .ai-jail/papers && exec uv run --quiet --with paper-search-mcp python scripts/paper-search-mcp-safe"],
      "lifecycle": "eager"
    }
  }
}
EOF

# The config's selector is `pi:<model>`; strip the harness prefix for pi's own --model flag.
MODEL="${RESEARCH_MODEL#pi:}"  # env override already folded in above

if [ "$#" -eq 0 ]; then
    echo "Usage: scripts/deep-research-pi '<research request>'" >&2
    echo >&2
    echo "Model comes from $CONF (currently: $MODEL). Override with DEEP_RESEARCH_MODEL." >&2
    echo >&2
    echo "Example (the golden prompt):" >&2
    echo "  scripts/deep-research-pi \"\$(cat prompts/examples/self-hosted-coding-model-golden.md)\"" >&2
    exit 2
fi

# The config outlives the machine it describes. Swap a model out of LiteLLM and the conf
# still names it — pi then fails with its own error, about a model, deep inside a run the
# user thought was starting. Check it against what the machine actually serves, now.
if ! pi --list-models 2>/dev/null | awk -v m="$MODEL" '$1 == "litellm" && $2 == m { found = 1 } END { exit !found }'; then
    echo "The model in $CONF is '$MODEL', and LiteLLM does not serve it." >&2
    echo >&2
    echo "It serves:" >&2
    pi --list-models 2>/dev/null | awk '$1 == "litellm" { print "  " $2 }' >&2
    echo >&2
    echo "Re-run scripts/setup to pick one, or set DEEP_RESEARCH_MODEL for this run." >&2
    exit 1
fi

# Firecrawl shuts itself down under memory pressure and exits 0, so a dead API looks like a
# clean stack. Check the search endpoint, not just liveness: a 200 on / only proves the
# process is up, while search is the thing the research actually depends on.
if ! curl -sf --max-time 5 -o /dev/null "${FIRECRAWL_API_URL:-http://localhost:3002}/"; then
    echo "Firecrawl is not answering at ${FIRECRAWL_API_URL:-http://localhost:3002}." >&2
    echo "Start it:   scripts/install-firecrawl" >&2
    echo "Or point at a hosted one:  scripts/setup" >&2
    exit 1
fi

cd "$ROOT"
exec pi \
    --provider litellm \
    --model "$MODEL" \
    --append-system-prompt "$ROOT/opencode/prompts/deep-research.md" \
    "$(printf 'Follow the deep research workflow in your system prompt. User research request:\n\n%s\n' "$*")"
