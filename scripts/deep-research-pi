#!/usr/bin/env bash
# Run the deep-research workflow through pi, against a model served by the local LiteLLM.
#
# WHY pi is worth a script of its own: it is the cheap harness. The whole point of routing
# research to GLM-5.2 (or another LiteLLM-served model) is that a deep run makes dozens of
# tool calls, and doing that on a frontier model costs real money for work that is mostly
# fetching and summarising. Use the expensive harnesses when the *reasoning* is the hard
# part; use this one for the legwork.
#
# pi reaches Firecrawl through the pi-mcp-extension (`pi install npm:pi-mcp-extension`),
# configured by `.pi/mcp.json` in this repo. Without that extension pi has no web access at
# all -- read, bash, edit, write and nothing else -- and the research prompt will (correctly)
# refuse to proceed rather than write a dossier from the model's memory.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CONF="$ROOT/.deep-research.conf"

if [ ! -f "$CONF" ]; then
    echo "No setup found. Run scripts/setup first — it detects what this machine has and asks" >&2
    echo "what you want to use (researching model, second opinion, review panel, depth budget)." >&2
    exit 2
fi
# shellcheck disable=SC1090
. "$CONF"

export FIRECRAWL_API_URL="${FIRECRAWL_API_URL:-http://localhost:3002}"
export FIRECRAWL_API_KEY="${FIRECRAWL_API_KEY:-}"

# pi-mcp-extension does NOT expand placeholders in .pi/mcp.json -- not `{env:VAR}`, not
# `${VAR}`. It passes the literal string through to firecrawl-mcp, which rejects it with a
# bare "Invalid URL" and no hint as to why. (opencode's config DOES expand `{env:VAR}`, which
# is exactly the sort of difference that makes a tool work on its author's machine and nowhere
# else.) So the file is generated from the config rather than templated: one source of truth,
# and the cloud path works without hand-editing JSON.
mkdir -p "$ROOT/.pi"
cat > "$ROOT/.pi/mcp.json" <<EOF
{
  "settings": { "toolPrefix": "mcp", "requestTimeoutMs": 60000, "maxRetries": 3 },
  "mcpServers": {
    "firecrawl": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_URL": "$FIRECRAWL_API_URL",
        "FIRECRAWL_API_KEY": "$FIRECRAWL_API_KEY"
      },
      "lifecycle": "eager"
    }
  }
}
EOF

# The config's selector is `pi:<model>`; strip the harness prefix for pi's own --model flag.
MODEL="${DEEP_RESEARCH_MODEL:-${RESEARCH_MODEL#pi:}}"

if [ "$#" -eq 0 ]; then
    echo "Usage: scripts/deep-research-pi '<research request>'" >&2
    echo >&2
    echo "Model comes from $CONF (currently: $MODEL). Override with DEEP_RESEARCH_MODEL." >&2
    echo >&2
    echo "Example (the golden prompt):" >&2
    echo "  scripts/deep-research-pi \"\$(cat prompts/examples/self-hosted-coding-model-golden.md)\"" >&2
    exit 2
fi

# Firecrawl shuts itself down under memory pressure and exits 0, so a dead API looks like a
# clean stack. Check the search endpoint, not just liveness: a 200 on / only proves the
# process is up, while search is the thing the research actually depends on.
if ! curl -sf --max-time 5 -o /dev/null "${FIRECRAWL_API_URL:-http://localhost:3002}/"; then
    echo "Firecrawl is not answering at ${FIRECRAWL_API_URL:-http://localhost:3002}." >&2
    echo "Start it:  docker compose -f ~/firecrawl/docker-compose.yaml up -d api" >&2
    exit 1
fi

cd "$ROOT"
exec pi \
    --provider litellm \
    --model "$MODEL" \
    --append-system-prompt "$ROOT/opencode/prompts/deep-research.md" \
    "$(printf 'Follow the deep research workflow in your system prompt. User research request:\n\n%s\n' "$*")"
