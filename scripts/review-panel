#!/usr/bin/env bash
# Fan a finished dossier out to N reviewers, then compute what they agree on.
#
# WHY this is a script and not a paragraph in the prompt: the last time this workflow asked
# an agent to do something important on the honour system -- "explore, don't just confirm
# the list" -- the agent didn't, and nothing noticed for two months. Depth got fixed by
# making it countable (the search ledger). Triangulation gets the same treatment: the panel
# is executed here, and the consensus is *computed* from the reviewers' tables, not
# adjudicated by the agent whose work is under review.
#
# The asymmetry with the second opinion (Gate 8.4, one model) is deliberate. A second
# opinion is a whole research run, so each extra model costs another run. A review is one
# read of a finished dossier -- cheap enough to buy several, and several is what turns a
# pile of opinions into a vote.
#
# Usage:
#   scripts/review-panel research/<slug> [round]
#   REVIEW_PANEL="agy pi:glm-5.2 pi:deepseek-v4-pro-high" scripts/review-panel research/<slug>
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DOSSIER="${1:-}"
ROUND="${2:-1}"

# The panel comes from your setup, never from a default baked in here: which models exist is a
# fact about YOUR machine, not about this tool. Hardcoding one setup's models is how a tool
# ends up quietly lying to everyone else -- they pick the model the docs offered, get a
# `blocked` reviewer, and have no idea why.
CONF="$ROOT/.deep-research.conf"
# shellcheck disable=SC1090
[ -f "$CONF" ] && . "$CONF"
PANEL="${REVIEW_PANEL:-}"

if [ -z "$DOSSIER" ] || [ ! -d "$ROOT/$DOSSIER" ]; then
    echo "Usage: scripts/review-panel research/<slug> [round]" >&2
    echo >&2
    echo "The panel comes from .deep-research.conf (scripts/setup), or \$REVIEW_PANEL." >&2
    echo "Selectors: claude:<model>, codex, agy, agy:flash, pi:<model>" >&2
    exit 2
fi

if [ -z "$PANEL" ] || [ "$PANEL" = "off" ]; then
    echo "No review panel configured (REVIEW_PANEL is '${PANEL:-unset}')." >&2
    echo >&2
    echo "Run scripts/setup to choose one, or set REVIEW_PANEL for this run." >&2
    echo "If the panel is deliberately off, the dossier must SAY it went unreviewed —" >&2
    echo "an unreviewed dossier that doesn't mention it reads exactly like one that passed." >&2
    exit 2
fi

OUT="$ROOT/$DOSSIER/review/panel-round-$ROUND"
mkdir -p "$OUT"

prompt_for() {
    printf 'Read and follow %s/prompts/reviewer.md.\n\nResearch directory: %s\nReview round: %s\nYour reviewer name: %s\n\nWrite your report to %s/%s.md\n' \
        "$ROOT" "$ROOT/$DOSSIER" "$ROUND" "$1" "$OUT" "$(echo "$1" | tr ':/' '__')"
}

echo "Panel: $PANEL"
echo "Dossier: $DOSSIER (round $ROUND)"
echo

for reviewer in $PANEL; do
    name="$(echo "$reviewer" | tr ':/' '__')"
    report="$OUT/$name.md"
    printf '  %-28s ' "$reviewer"

    # A reviewer that cannot be invoked is recorded as `blocked`, never silently dropped:
    # a panel of three that quietly became a panel of two still reports as a panel, and the
    # consensus rule ("2 or more agree") would then be computed against a denominator that
    # is a lie.
    ok=false
    case "$reviewer" in
        pi:*)
            (cd "$ROOT" && timeout 900 pi --print --provider litellm --model "${reviewer#pi:}" \
                "$(prompt_for "$reviewer")" >"$OUT/$name.stderr" 2>&1) && ok=true
            ;;
        claude:*)
            (cd "$ROOT" && timeout 900 claude --print --model "${reviewer#claude:}" \
                --permission-mode acceptEdits "$(prompt_for "$reviewer")" >"$OUT/$name.stderr" 2>&1) && ok=true
            ;;
        agy:flash)
            (cd "$ROOT" && timeout 900 agy --add-dir "$ROOT" --model "Gemini 3.5 Flash (High)" \
                --print "$(prompt_for "$reviewer")" >"$OUT/$name.stderr" 2>&1) && ok=true
            ;;
        agy)
            (cd "$ROOT" && timeout 900 agy --add-dir "$ROOT" \
                --print "$(prompt_for agy)" >"$OUT/$name.stderr" 2>&1) && ok=true
            ;;
        codex)
            (cd "$ROOT" && timeout 900 codex exec --cd "$ROOT" --sandbox danger-full-access \
                "$(prompt_for codex)" >"$OUT/$name.stderr" 2>&1) && ok=true
            ;;
        *)
            echo "UNKNOWN — not in docs/reviewers.md"
            ;;
    esac

    if $ok && [ -s "$report" ]; then
        echo "ok"
    else
        echo "BLOCKED"
        # shellcheck disable=SC2016  # the %s are printf placeholders, not shell expansions
        why="$(tail -3 "$OUT/$name.stderr" 2>/dev/null || echo "no output captured")"
        printf -- '---\ntype: external-review\nreviewer: %s\nround: %s\nstatus: blocked\nverdict: blocked\n---\n\n# Review — %s — Round %s\n\nReviewer could not be invoked, or produced no report.\n\n```\n%s\n```\n' \
            "$reviewer" "$ROUND" "$reviewer" "$ROUND" "$why" > "$report"
    fi
done

echo
echo "Computing consensus..."
OUT="$OUT" ROUND="$ROUND" python3 "$ROOT/scripts/consensus.py"
echo "Wrote $DOSSIER/review/panel-round-$ROUND/consensus.md"
