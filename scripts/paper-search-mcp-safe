#!/usr/bin/env python3
"""Run paper-search-mcp with Sci-Hub disabled unless explicitly enabled."""

from __future__ import annotations

import os


FALSE_VALUES = {"", "0", "false", "no", "off"}


def scihub_enabled() -> bool:
    value = os.environ.get("PAPER_SEARCH_MCP_ENABLE_SCIHUB", "")
    return value.strip().lower() not in FALSE_VALUES


def remove_tool_if_present(mcp, name: str) -> None:
    try:
        mcp.remove_tool(name)
    except Exception:
        pass


def main() -> None:
    from paper_search_mcp import server as upstream

    enabled = scihub_enabled()
    original_download_with_fallback = upstream.download_with_fallback

    remove_tool_if_present(upstream.mcp, "download_with_fallback")
    if not enabled:
        remove_tool_if_present(upstream.mcp, "download_scihub")

    @upstream.mcp.tool(name="download_with_fallback")
    async def download_with_fallback(
        source: str,
        paper_id: str,
        doi: str = "",
        title: str = "",
        save_path: str = ".ai-jail/papers",
        use_scihub: bool = True,
        scihub_base_url: str = "https://sci-hub.se",
    ) -> str:
        """Try source-native and open-access fallbacks before optional Sci-Hub.

        Sci-Hub is unavailable unless PAPER_SEARCH_MCP_ENABLE_SCIHUB=true is
        set in the process environment, normally through local/paper-search-mcp.env.
        """
        return await original_download_with_fallback(
            source=source,
            paper_id=paper_id,
            doi=doi,
            title=title,
            save_path=save_path,
            use_scihub=enabled and use_scihub,
            scihub_base_url=scihub_base_url,
        )

    upstream.mcp.run(transport="stdio")


if __name__ == "__main__":
    main()
