#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [ "$#" -eq 0 ]; then
  echo "Usage: scripts/deep-research-agy '<research request>'" >&2
  echo "Example: scripts/deep-research-agy \"$(tr '\n' ' ' < "$ROOT/prompts/examples/llm-models-golden.md" | sed 's/"/\\"/g')\"" >&2
  exit 2
fi

cd "$ROOT"
agy \
  --add-dir "$ROOT" \
  --prompt-interactive "$(printf 'Read and follow agy/prompts/deep-research.md. User research request:\n\n%s\n' "$*")"

