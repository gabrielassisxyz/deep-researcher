# Written for you by scripts/setup — you should not need to edit this by hand.
#
# Firecrawl gives the research agent its web search and scrape tools. Without it there is no
# discovery, and "deep research" collapses into re-reading URLs you handed the agent yourself.
#
# Two ways to have one:
#   self-hosted  scripts/install-firecrawl   (6 containers; free, private, no rate limit)
#   hosted       an API key from firecrawl.dev, and set the URL below to its endpoint
FIRECRAWL_API_URL=http://localhost:3002
FIRECRAWL_API_KEY=

# Context7 is optional, and improves rate limits for library documentation lookup.
CONTEXT7_API_KEY=
