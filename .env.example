# Firecrawl unlocks crawl, map, agent, and extract tools for live web/docs work.
# The local Docker compose in ~/firecrawl exposes the API on this URL.
FIRECRAWL_API_URL=http://localhost:3002
FIRECRAWL_API_KEY=

# Context7 is optional, but improves rate limits for library documentation lookup.
CONTEXT7_API_KEY=
