# Written for you by scripts/setup — you should not need to edit this by hand.
#
# Firecrawl gives the research agent its web search and scrape tools. Without it there is no
# discovery, and "deep research" collapses into re-reading URLs you handed the agent yourself.
#
# Two ways to have one:
#   self-hosted  scripts/install-firecrawl   (6 containers; free, private, no rate limit)
#   hosted       an API key from firecrawl.dev, and set the URL below to its endpoint
FIRECRAWL_API_URL=http://localhost:3002
FIRECRAWL_API_KEY=

# Context7 is optional, and improves rate limits for library documentation lookup.
CONTEXT7_API_KEY=

# Paper search MCPs. These are optional; configure them only when the research
# run needs academic-paper discovery or retrieval.
PAPER_SEARCH_MCP_UNPAYWALL_EMAIL=
PAPER_SEARCH_MCP_CORE_API_KEY=
PAPER_SEARCH_MCP_SEMANTIC_SCHOLAR_API_KEY=
PAPER_SEARCH_MCP_DOAJ_API_KEY=
PAPER_SEARCH_MCP_ZENODO_ACCESS_TOKEN=
PAPER_SEARCH_MCP_GOOGLE_SCHOLAR_PROXY_URL=

# Public default: disabled. To enable on a specific machine, put this in
# local/paper-search-mcp.env instead of committing it here:
# PAPER_SEARCH_MCP_ENABLE_SCIHUB=true
PAPER_SEARCH_MCP_ENABLE_SCIHUB=false
