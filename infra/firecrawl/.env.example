# Copied to .env and filled in by scripts/install-firecrawl (which generates the passwords).
# Everything runs on the host network, so the services reach each other over localhost.

PORT=3002
HOST=0.0.0.0

# Generated — do not commit the resulting .env.
POSTGRES_USER=firecrawl
POSTGRES_PASSWORD=__GENERATED__
POSTGRES_DB=firecrawl
RABBITMQ_DEFAULT_USER=firecrawl
RABBITMQ_DEFAULT_PASS=__GENERATED__
BULL_AUTH_KEY=__GENERATED__

REDIS_URL=redis://localhost:6379
REDIS_RATE_LIMIT_URL=redis://localhost:6379
RABBITMQ_URL=amqp://firecrawl:__GENERATED__@localhost:5672
DATABASE_URL=postgres://firecrawl:__GENERATED__@localhost:5432/firecrawl
NUQ_DATABASE_URL=postgres://firecrawl:__GENERATED__@localhost:5432/firecrawl
NUQ_RABBITMQ_URL=amqp://firecrawl:__GENERATED__@localhost:5672
NUQ_REDIS_URL=redis://localhost:6379

# No API key needed against your own instance.
USE_DB_AUTHENTICATION=false

NUM_WORKERS_PER_QUEUE=8
PLAYWRIGHT_MICROSERVICE_URL=http://localhost:3000/scrape

# This is what gives Firecrawl a *search* endpoint. Drop it and the API can still scrape a URL
# you hand it, but it cannot discover anything — which makes deep research impossible.
SEARXNG_ENDPOINT=http://localhost:4080

BLOCK_MEDIA=true

# Firecrawl refuses connections and eventually shuts itself down above these — cleanly, exit 0,
# while every other container stays up and the stack looks healthy. If research runs die
# mid-way on a busy machine, raise these first.
MAX_CPU=0.95
MAX_RAM=0.95
